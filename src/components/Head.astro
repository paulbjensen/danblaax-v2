---
const { stylesheets } = Astro.props;
---

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
        name="keywords"
        content="Dan Blaax, Saxophonist, Dubai Saxophonist, Live Saxophone, Event Entertainment, Saxophone Performer, Party Saxophonist, Sax Music Dubai, Book Saxophonist, Saxophone Shows"
    />
    <meta
        name="description"
        content="Dan Blaax - The Maverick of the sax world. Dubai-based saxophonist lighting up audiences worldwide with epic sax melodies. New site coming soon"
    />
    <title>Dan Blaax</title>
    {stylesheets.map((href) => <link rel="stylesheet" href={href} />)}
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="icon" href="/favicon/favicon.ico" />
</head>
